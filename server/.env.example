# Server
PORT=4242

# Public base URL used for webhook metadata fallback links.
# Example: https://anngelj.com
PUBLIC_SITE_URL=

# Supabase project URL (server-side use).
# Example: https://your-project.supabase.co
SUPABASE_URL=

# Supabase service role key (SERVER ONLY, never expose in frontend).
SUPABASE_SERVICE_ROLE_KEY=

# Stripe secret key (required)
# Example: sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (SERVER ONLY, never expose in frontend).
# Example: whsec_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=

# Optional: limit allowed frontend origins
# comma-separated list (for example: http://127.0.0.1:5500,http://localhost:5500)
ALLOWED_ORIGINS=
